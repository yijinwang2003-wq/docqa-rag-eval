OPENAI_API_KEY=

# Override these if your account or eval needs a different model.
OPENAI_CHAT_MODEL=gpt-5.5
OPENAI_EVAL_MODEL=gpt-5-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Local ChromaDB settings.
DOCQA_CHROMA_DIR=.chroma
DOCQA_CHROMA_COLLECTION=technical_docs

# Retrieval and chunking defaults.
DOCQA_RETRIEVER_K=4
DOCQA_CHUNK_SIZE=1000
DOCQA_CHUNK_OVERLAP=200
DOCQA_SEMANTIC_SIMILARITY_THRESHOLD=0.78
DOCQA_SEMANTIC_MIN_CHUNK_SIZE=500
DOCQA_SEMANTIC_MAX_CHUNK_SIZE=2000

# Polite default for docs scraping.
USER_AGENT=docqa-rag-eval/0.1
